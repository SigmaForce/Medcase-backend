generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  reviewer
  admin
}

enum SubscriptionPlan {
  free
  pro
  institutional
}

enum SubscriptionStatus {
  active
  inactive
  trial
  past_due
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  country      String
  university   String
  role         UserRole @default(student)
  isActive     Boolean  @default(false) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscription        Subscription?
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  auditLogs           AuditLog[]
  casesCreated        ClinicalCase[]      @relation("CasesCreated")
  casesReviewed       ClinicalCase[]      @relation("CasesReviewed")
  sessions            Session[]
  studentPerformance  StudentPerformance[]
  caseRatings         CaseRating[]
  reviewedQueueItems  CaseReviewQueue[]   @relation("ReviewedBy")
  badges              UserBadge[]
  streak              UserStreak?
  inviteCodesCreated  InviteCode[]        @relation("InviteCodesCreated")
  inviteCodesUsed     InviteCode?         @relation("InviteCodesUsed")

  @@map("users")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @unique @map("user_id") @db.Uuid
  plan              SubscriptionPlan   @default(free)
  status            SubscriptionStatus @default(active)
  casesLimit        Int                @default(5) @map("cases_limit")
  casesUsed         Int                @default(0) @map("cases_used")
  generationsLimit  Int                @default(0) @map("generations_limit")
  generationsUsed   Int                @default(0) @map("generations_used")
  usageResetAt      DateTime           @map("usage_reset_at")
  provider          String?
  externalSubId     String?            @map("external_sub_id")
  externalCustomer  String?            @map("external_customer")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  cancelAt          DateTime?          @map("cancel_at")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id") @db.Uuid
  meta      Json     @default("{}")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Clinical Cases ────────────────────────────────────────────────────────────

enum CaseDifficulty {
  beginner
  intermediate
  advanced
}

enum CaseLanguage {
  pt
  es
}

enum CountryContext {
  BR
  PY
}

enum CaseStatus {
  draft
  pending_review
  approved
  rejected
  regenerating
}

model Specialty {
  id      Int    @id @default(autoincrement())
  slug    String @unique
  namePt  String @map("name_pt")
  nameEs  String @map("name_es")
  icon    String?

  clinicalCases      ClinicalCase[]
  studentPerformance StudentPerformance[]

  @@map("specialties")
}

model ClinicalCase {
  id               String         @id @default(uuid()) @db.Uuid
  specialtyId      Int            @map("specialty_id")
  createdById      String         @map("created_by") @db.Uuid
  reviewedById     String?        @map("reviewed_by") @db.Uuid
  title            String
  difficulty       CaseDifficulty
  language         CaseLanguage
  countryContext   CountryContext  @map("country_context")
  status           CaseStatus     @default(pending_review)
  caseBrief        Json           @map("case_brief")
  availableExams   Json           @default("{}") @map("available_exams")
  generationPrompt String?        @map("generation_prompt")
  avgRating        Decimal        @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalRatings     Int            @default(0) @map("total_ratings")
  flaggedCount     Int            @default(0) @map("flagged_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  specialty   Specialty         @relation(fields: [specialtyId], references: [id])
  createdBy   User              @relation("CasesCreated", fields: [createdById], references: [id])
  reviewedBy  User?             @relation("CasesReviewed", fields: [reviewedById], references: [id])
  sessions    Session[]
  ratings     CaseRating[]
  reviewQueue CaseReviewQueue[]

  @@map("clinical_cases")
}

// ─── Sessions ──────────────────────────────────────────────────────────────────

enum SessionStatus {
  in_progress
  completed
  abandoned
}

enum MessageRole {
  user
  assistant
  system
}

model Session {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  caseId              String        @map("case_id") @db.Uuid
  status              SessionStatus @default(in_progress)
  submittedDiagnosis  String?       @map("submitted_diagnosis")
  submittedManagement String?       @map("submitted_management")
  feedback            Json?
  requestedExams      String[]      @default([]) @map("requested_exams")
  missedKeyExams      String[]      @default([]) @map("missed_key_exams")
  startedAt           DateTime      @default(now()) @map("started_at")
  completedAt         DateTime?     @map("completed_at")
  durationSecs        Int?          @map("duration_secs")
  isTimed             Boolean       @default(false) @map("is_timed")
  timedLimitSecs      Int           @default(2700) @map("timed_limit_secs")
  sessionType         String        @default("study") @map("session_type")

  user     User         @relation(fields: [userId], references: [id])
  case     ClinicalCase @relation(fields: [caseId], references: [id])
  messages Message[]

  @@index([userId])
  @@index([caseId])
  @@map("sessions")
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      MessageRole
  content   String
  meta      Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
  @@map("messages")
}

// ─── Student Performance ───────────────────────────────────────────────────────

model StudentPerformance {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  specialtyId     Int      @map("specialty_id")
  totalSessions   Int      @default(0) @map("total_sessions")
  avgScoreTotal   Decimal  @default(0) @map("avg_score_total") @db.Decimal(5, 2)
  avgHistoryTaking Decimal @default(0) @map("avg_history_taking") @db.Decimal(5, 2)
  avgDifferential  Decimal @default(0) @map("avg_differential") @db.Decimal(5, 2)
  avgDiagnosis     Decimal @default(0) @map("avg_diagnosis") @db.Decimal(5, 2)
  avgExams         Decimal @default(0) @map("avg_exams") @db.Decimal(5, 2)
  avgManagement    Decimal @default(0) @map("avg_management") @db.Decimal(5, 2)
  lastSessionAt    DateTime? @map("last_session_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id])
  specialty Specialty @relation(fields: [specialtyId], references: [id])

  @@unique([userId, specialtyId], name: "unique_perf")
  @@map("student_performance")
}

// ─── Curation ──────────────────────────────────────────────────────────────────

model CaseRating {
  id        String   @id @default(uuid()) @db.Uuid
  caseId    String   @map("case_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  score     Int
  issues    String[] @default([])
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  case ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId], name: "one_rating_per_case")
  @@map("case_ratings")
}

model CaseReviewQueue {
  id           String    @id @default(uuid()) @db.Uuid
  caseId       String    @map("case_id") @db.Uuid
  reviewedById String?   @map("reviewed_by") @db.Uuid
  status       String    @default("pending")
  regenerations Int      @default(0)
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  case       ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reviewedBy User?        @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("case_review_queue")
}

// ─── Gamification ──────────────────────────────────────────────────────────────

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badgeSlug String   @map("badge_slug")
  earnedAt  DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeSlug], name: "unique_badge")
  @@map("user_badges")
}

model UserStreak {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastActivityAt DateTime? @map("last_activity_at")
  totalSessions Int       @default(0) @map("total_sessions")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

// ─── Phase 4: Payments, Invites, Analytics ────────────────────────────────────

model PaymentEvent {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  provider    String
  eventType   String   @map("event_type")
  externalId  String   @map("external_id")
  amountCents Int?     @map("amount_cents")
  currency    String?
  status      String?
  rawPayload  Json     @map("raw_payload")
  processedAt DateTime @default(now()) @map("processed_at")

  @@unique([provider, externalId], name: "unique_external_event")
  @@map("payment_events")
}

model InviteCode {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  createdById String    @map("created_by") @db.Uuid
  usedById    String?   @unique @map("used_by") @db.Uuid
  label       String?
  trialDays   Int       @default(30) @map("trial_days")
  expiresAt   DateTime  @map("expires_at") @db.Date
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  createdBy User  @relation("InviteCodesCreated", fields: [createdById], references: [id])
  usedBy    User? @relation("InviteCodesUsed", fields: [usedById], references: [id])

  @@map("invite_codes")
}

model UsageMetric {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String?  @map("session_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  operation    String
  model        String
  tokensInput  Int      @map("tokens_input")
  tokensOutput Int      @map("tokens_output")
  latencyMs    Int?     @map("latency_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("usage_metrics")
}
