DATABASE_URL="postgresql://postgres:postgres@localhost:5432/revalidai?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=revalidai
POSTGRES_PORT=5432

# JWT
JWT_SECRET="generate_a_secure_random_string_min_32_chars"
JWT_REFRESH_SECRET="another_secure_random_string_min_32_chars"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Resend (Email)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# App
APP_URL="http://localhost:3000"
